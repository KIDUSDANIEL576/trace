{
  "expo": {
    "name": "Trace",
    "slug": "trace",
    "version": "0.1.0",
    "scheme": "trace",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0c0b10",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c0b10"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.digirafthub.trace",
      "entitlements": {
        "com.apple.security.application-groups": ["group.com.digirafthub.trace"]
      }
    },
    "android": {
      "package": "com.digirafthub.trace",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0c0b10"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#e23343"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Trace uses your photos so you can draw on one together.",
          "cameraPermission": "Trace uses the camera so you can take a photo to draw on together."
        }
      ],
      "@bacons/apple-targets"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
